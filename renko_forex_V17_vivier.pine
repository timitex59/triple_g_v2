//@version=6
indicator("renko_forex_V17_VIVIER", shorttitle="RF_V17_VIVIER", overlay=true, dynamic_requests=true, max_labels_count=500, max_lines_count=100)

// This indicator mirrors the single-pair VIVIER state machine implemented in
// renko_score_29pairs_v16.py. Use it on a standard OANDA 1H candlestick chart.

groupRenko = "Renko"
groupVivier = "VIVIER"
groupSar = "Parabolic SAR / Flames"
groupFib = "Fibonacci (Monthly Transition)"
groupDisplay = "Display"
groupColors = "Colors"

atrLength = input.int(14, "ATR Length", minval=1, group=groupRenko)
maxStreakBars = input.int(50, "Max Streak Bricks", minval=5, maxval=200, group=groupRenko)
priceMode = input.string("H1 Close (Python)", "Price Compared To Renko", options=["H1 Close (Python)", "Daily Live Close"], group=groupRenko)

weightMonthly = input.float(3.0, "Monthly Weight", minval=0.0, group=groupVivier)
weightWeekly = input.float(2.0, "Weekly Weight", minval=0.0, group=groupVivier)
weightDaily = input.float(1.0, "Daily Weight", minval=0.0, group=groupVivier)
vivierMinScore = input.float(33.0, "Minimum Absolute Base Score (%)", minval=0.0, maxval=100.0, step=1.0, group=groupVivier)
fibMidpointPct = input.float(50.0, "Entry Fibonacci Midpoint (%)", minval=0.0, maxval=100.0, step=1.0, group=groupVivier)
scoreThreshold = input.float(60.0, "RENKO FIBO Final Score (%)", minval=0.0, maxval=100.0, step=5.0, group=groupVivier)

showSar = input.bool(true, "Show Parabolic SAR", group=groupSar)
showAllSarCrosses = input.bool(false, "Show All H1 SAR Crosses", group=groupSar)
sarStart = input.float(0.1, "Start", minval=0.0, group=groupSar)
sarIncrement = input.float(0.1, "Increment", minval=0.0, group=groupSar)
sarMaximum = input.float(0.2, "Maximum", minval=0.0, group=groupSar)

showFib = input.bool(true, "Show Fibonacci Levels", group=groupFib)
fibExtendBars = input.int(60, "Extend Bars", minval=10, maxval=500, group=groupFib)
showFibLabels = input.bool(true, "Show Fibonacci Labels", group=groupFib)
showFib236 = input.bool(true, "Show 0.236", group=groupFib)
showFib382 = input.bool(true, "Show 0.382", group=groupFib)
showFib500 = input.bool(true, "Show 0.500", group=groupFib)
showFib618 = input.bool(true, "Show 0.618", group=groupFib)
showFib786 = input.bool(true, "Show 0.786", group=groupFib)
showFibExtremes = input.bool(true, "Show 0 and 1", group=groupFib)
showCarriedObjective = input.bool(true, "Show Carried Objective", group=groupFib)
fibTransitionMinDays = input.int(5, "Transition: Minimum Trading Days", minval=1, maxval=10, group=groupFib)
fibTransitionMinRangePct = input.float(60.0, "Transition: Minimum Previous Range (%)", minval=0.0, maxval=100.0, step=5.0, group=groupFib)
fibTransitionForceDay = input.int(11, "Transition: Force Current Month From Day", minval=2, maxval=20, group=groupFib)

showEventLabels = input.bool(true, "Show VIVIER Event Labels", group=groupDisplay)
showAllProcessTouches = input.bool(true, "Show Every Fibo 1/0 Touch During VIVIER", group=groupDisplay)
showVivierBackground = input.bool(true, "Color Background While In VIVIER", group=groupDisplay)
tablePosition = input.string("Bottom Right", "Table Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=groupDisplay)

bullColor = input.color(color.new(color.green, 0), "Bull", group=groupColors)
bearColor = input.color(color.new(color.red, 0), "Bear", group=groupColors)
neutralColor = input.color(color.new(color.gray, 55), "Neutral", group=groupColors)
headerColor = input.color(color.new(color.rgb(42, 46, 57), 0), "Header", group=groupColors)
fibColor = input.color(color.new(color.black, 0), "Fibonacci", group=groupColors)
fibLowColor = input.color(color.new(color.green, 0), "Fibo 0", group=groupColors)
fibHighColor = input.color(color.new(color.red, 0), "Fibo 1", group=groupColors)
carriedObjectiveColor = input.color(color.new(color.blue, 0), "Carried Objective", group=groupColors)
sarColor = input.color(color.new(color.black, 0), "SAR", group=groupColors)

f_table_position(_position) =>
    _position == "Top Left" ? position.top_left : _position == "Bottom Right" ? position.bottom_right : _position == "Bottom Left" ? position.bottom_left : position.top_right

f_dir_text(_direction) =>
    _direction == 1 ? "BULL" : _direction == -1 ? "BEAR" : "MIXED"

f_dir_color(_direction) =>
    _direction == 1 ? bullColor : _direction == -1 ? bearColor : neutralColor

f_px_symbol(_state) =>
    _state == 1 ? "+" : _state == -1 ? "-" : "0"

f_px_text(_m, _w, _d) =>
    "M" + f_px_symbol(_m) + " / W" + f_px_symbol(_w) + " / D" + f_px_symbol(_d)

f_month_key(_year, _month) =>
    str.tostring(_year) + "-" + (_month < 10 ? "0" : "") + str.tostring(_month)

f_px_state(_renkoOpen, _renkoClose, _price) =>
    float _high = math.max(_renkoOpen, _renkoClose)
    float _low = math.min(_renkoOpen, _renkoClose)
    _price > _high ? 1 : _price < _low ? -1 : 0

f_green_streak(_maxBars) =>
    int _count = 0
    for i = 0 to _maxBars - 1
        if close[i] > open[i]
            _count += 1
        else
            break
    _count

f_red_streak(_maxBars) =>
    int _count = 0
    for i = 0 to _maxBars - 1
        if close[i] < open[i]
            _count += 1
        else
            break
    _count

f_streak_low(_maxBars) =>
    int _direction = close > open ? 1 : close < open ? -1 : 0
    float _value = na
    if _direction != 0
        for i = 0 to _maxBars - 1
            int _brickDirection = close[i] > open[i] ? 1 : close[i] < open[i] ? -1 : 0
            if _brickDirection != _direction
                break
            float _brickLow = math.min(open[i], close[i])
            _value := na(_value) ? _brickLow : math.min(_value, _brickLow)
    _value

f_streak_high(_maxBars) =>
    int _direction = close > open ? 1 : close < open ? -1 : 0
    float _value = na
    if _direction != 0
        for i = 0 to _maxBars - 1
            int _brickDirection = close[i] > open[i] ? 1 : close[i] < open[i] ? -1 : 0
            if _brickDirection != _direction
                break
            float _brickHigh = math.max(open[i], close[i])
            _value := na(_value) ? _brickHigh : math.max(_value, _brickHigh)
    _value

f_effective_bias(_pxState, _greenStreak, _redStreak) =>
    _pxState == 1 ? 1 : _pxState == -1 ? -1 : _greenStreak > 0 and _redStreak == 0 ? 1 : _greenStreak == 0 and _redStreak > 0 ? -1 : 0

f_chg_coeff(_chgPct, _direction) =>
    float _coefficient = 0.0
    if not na(_chgPct)
        bool _rightDirection = (_direction == 1 and _chgPct > 0.0) or (_direction == -1 and _chgPct < 0.0)
        if _rightDirection
            float _absolute = math.abs(_chgPct)
            _coefficient := _absolute <= 0.1 ? 0.0 : _absolute <= 0.15 ? 0.5 : _absolute <= 0.2 ? 0.6 : _absolute <= 0.3 ? 0.8 : _absolute <= 0.4 ? 0.9 : _absolute <= 0.5 ? 0.95 : 1.0
    _coefficient

f_fib_directional_text(_ratio, _direction) =>
    string _text = "?"
    if not na(_ratio)
        if _direction == 1
            _text := _ratio < 0.0 ? "<0" : _ratio < 0.236 ? "<0.236" : _ratio < 0.382 ? "<0.382" : _ratio < 0.500 ? "<0.500" : _ratio < 0.618 ? "<0.618" : _ratio < 0.786 ? "<0.786" : _ratio < 1.0 ? "<1" : ">1"
        else if _direction == -1
            _text := _ratio > 1.0 ? ">1" : _ratio > 0.786 ? ">0.786" : _ratio > 0.618 ? ">0.618" : _ratio > 0.500 ? ">0.500" : _ratio > 0.382 ? ">0.382" : _ratio > 0.236 ? ">0.236" : _ratio > 0.0 ? ">0" : "<0"
    _text

f_entry_direction(_m, _w, _d, _score, _fibPct) =>
    int _direction = _m
    bool _monthlyValid = _direction == 1 or _direction == -1
    bool _strictOpposition = _monthlyValid and (_w == -_direction or _d == -_direction)
    bool _alignedWeeklyInsideDaily = _monthlyValid and _w == _direction and _d == 0
    bool _profileValid = _strictOpposition or _alignedWeeklyInsideDaily
    bool _scoreValid = not na(_score) and math.abs(_score) >= vivierMinScore
    bool _fibValid = not na(_fibPct) and ((_direction == 1 and _fibPct <= fibMidpointPct) or (_direction == -1 and _fibPct >= fibMidpointPct))
    _monthlyValid and _profileValid and _scoreValid and _fibValid ? _direction : 0

f_new_sar_record(_direction, _crossDirection, _sar, _fib500, _record) =>
    bool _crossValid = _crossDirection == _direction
    bool _fibValid = _direction == 1 ? _sar < _fib500 : _sar > _fib500
    bool _recordValid = na(_record) or (_direction == 1 ? _sar < _record : _sar > _record)
    _crossValid and not na(_sar) and not na(_fib500) and _fibValid and _recordValid

f_update_fib(_line, _label, _enabled, _active, _startTime, _endTime, _price, _ratioText, _lineColor) =>
    if _enabled and showFib and _active and not na(_startTime) and not na(_price)
        line.set_xy1(_line, _startTime, _price)
        line.set_xy2(_line, _endTime, _price)
        line.set_color(_line, _lineColor)
        label.set_xy(_label, _endTime, _price)
        label.set_text(_label, showFibLabels ? _ratioText + "  " + str.tostring(_price, format.mintick) : "")
        label.set_textcolor(_label, fibColor)
    else
        line.set_color(_line, color.new(_lineColor, 100))
        label.set_text(_label, "")

f_finish_carried_line(_line, _label, _endTime, _suffix, _color) =>
    if not na(_line)
        line.set_x2(_line, _endTime)
        line.set_extend(_line, extend.none)
        line.set_color(_line, _color)
    if not na(_label)
        label.set_text(_label, "OBJECTIF REPORTE " + _suffix)
        label.set_textcolor(_label, _color)

// Standard OHLC is requested explicitly so calculations do not inherit a
// non-standard chart's synthetic candles.
baseTicker = ticker.new(syminfo.prefix, syminfo.ticker)
[h1Open, h1High, h1Low, h1Close, h1Time, sarValue] = request.security(baseTicker, "60", [open, high, low, close, time, ta.sar(sarStart, sarIncrement, sarMaximum)], barmerge.gaps_off, barmerge.lookahead_off)
[dailyLiveClose, previousDailyClose] = request.security(baseTicker, "D", [close, close[1]], barmerge.gaps_off, barmerge.lookahead_off)
dailyChgPct = request.security(baseTicker, "D", close[1] != 0.0 ? (close - close[1]) / close[1] * 100.0 : float(na), barmerge.gaps_off, barmerge.lookahead_off)

renkoTicker = ticker.renko(baseTicker, "ATR", atrLength)
[renkoOpenM, renkoCloseM, greenM, redM, streakLowM, streakHighM] = request.security(renkoTicker, "M", [open, close, f_green_streak(maxStreakBars), f_red_streak(maxStreakBars), f_streak_low(maxStreakBars), f_streak_high(maxStreakBars)], barmerge.gaps_off, barmerge.lookahead_off)
[renkoOpenW, renkoCloseW, greenW, redW, streakLowW, streakHighW] = request.security(renkoTicker, "W", [open, close, f_green_streak(maxStreakBars), f_red_streak(maxStreakBars), f_streak_low(maxStreakBars), f_streak_high(maxStreakBars)], barmerge.gaps_off, barmerge.lookahead_off)
[renkoOpenD, renkoCloseD, greenD, redD, streakLowD, streakHighD] = request.security(renkoTicker, "D", [open, close, f_green_streak(maxStreakBars), f_red_streak(maxStreakBars), f_streak_low(maxStreakBars), f_streak_high(maxStreakBars)], barmerge.gaps_off, barmerge.lookahead_off)

referencePrice = priceMode == "Daily Live Close" ? dailyLiveClose : h1Close
dataReady = not na(referencePrice) and not na(renkoOpenM) and not na(renkoCloseM) and not na(renkoOpenW) and not na(renkoCloseW) and not na(renkoOpenD) and not na(renkoCloseD)

pxM = dataReady ? f_px_state(renkoOpenM, renkoCloseM, referencePrice) : 0
pxW = dataReady ? f_px_state(renkoOpenW, renkoCloseW, referencePrice) : 0
pxD = dataReady ? f_px_state(renkoOpenD, renkoCloseD, referencePrice) : 0

biasM = dataReady ? f_effective_bias(pxM, greenM, redM) : 0
biasW = dataReady ? f_effective_bias(pxW, greenW, redW) : 0
biasD = dataReady ? f_effective_bias(pxD, greenD, redD) : 0
signalState = biasM == 1 and biasW == 1 and biasD == 1 ? 1 : biasM == -1 and biasW == -1 and biasD == -1 ? -1 : 0

maxScore = weightMonthly + weightWeekly + weightDaily
baseScorePct = dataReady and maxScore != 0.0 ? (pxM * weightMonthly + pxW * weightWeekly + pxD * weightDaily) / maxScore * 100.0 : na
coefficientDirection = signalState != 0 ? signalState : not na(baseScorePct) and baseScorePct >= 0.0 ? 1 : -1
chgCoefficient = f_chg_coeff(dailyChgPct, coefficientDirection)
finalScorePct = na(baseScorePct) ? na : baseScorePct * chgCoefficient

strictBull = greenM >= 1 and greenW >= 1 and greenD >= 2 and pxM >= 0 and pxW == 1 and pxD == 1
strictBear = redM >= 1 and redW >= 1 and redD >= 2 and pxM <= 0 and pxW == -1 and pxD == -1
confirmedBull = signalState == 1 and strictBull and not na(finalScorePct) and finalScorePct >= scoreThreshold
confirmedBear = signalState == -1 and strictBear and not na(finalScorePct) and finalScorePct <= -scoreThreshold
confirmedState = confirmedBull ? 1 : confirmedBear ? -1 : 0

// Effective monthly Fibonacci, calculated from standard H1 candles in UTC.
// At a month reset, the completed previous month stays active until the new
// range is mature and agrees around 0.5, or until the forced relay day.
utcMonth = month(h1Time, "UTC+0")
utcYear = year(h1Time, "UTC+0")
utcDay = dayofmonth(h1Time, "UTC+0")
utcWeekday = dayofweek(h1Time, "UTC+0")
currentMonthKey = f_month_key(utcYear, utcMonth)
currentMonthId = utcYear * 100 + utcMonth
newMonth = na(h1Time[1]) or utcMonth != month(h1Time[1], "UTC+0") or utcYear != year(h1Time[1], "UTC+0")
newUtcDay = na(h1Time[1]) or utcDay != dayofmonth(h1Time[1], "UTC+0") or newMonth
isTradingDay = utcWeekday != dayofweek.saturday and utcWeekday != dayofweek.sunday
var float fibMonthHigh = na
var float fibMonthLow = na
var int fibMonthStartTime = na
var float fibPreviousHigh = na
var float fibPreviousLow = na
var int fibPreviousStartTime = na
var string fibPreviousMonthKey = ""
var int fibPreviousMonthId = na
var int fibCurrentTradingDays = 0
float fibHighBefore = newMonth ? na : fibMonthHigh
float fibLowBefore = newMonth ? na : fibMonthLow
if newMonth or na(fibMonthHigh)
    if not na(fibMonthHigh) and not na(fibMonthLow) and not na(h1Time[1])
        fibPreviousHigh := fibMonthHigh
        fibPreviousLow := fibMonthLow
        fibPreviousStartTime := fibMonthStartTime
        fibPreviousMonthKey := f_month_key(year(h1Time[1], "UTC+0"), month(h1Time[1], "UTC+0"))
        fibPreviousMonthId := year(h1Time[1], "UTC+0") * 100 + month(h1Time[1], "UTC+0")
    fibMonthHigh := h1High
    fibMonthLow := h1Low
    fibMonthStartTime := h1Time
    fibCurrentTradingDays := isTradingDay ? 1 : 0
else
    fibMonthHigh := math.max(fibMonthHigh, h1High)
    fibMonthLow := math.min(fibMonthLow, h1Low)
    if newUtcDay and isTradingDay
        fibCurrentTradingDays += 1

fibCurrentRange = fibMonthHigh - fibMonthLow
fibPreviousRange = fibPreviousHigh - fibPreviousLow
fibCurrentActive = not na(fibCurrentRange) and fibCurrentRange > 0.0
fibPreviousActive = not na(fibPreviousRange) and fibPreviousRange > 0.0
fibCurrentRatio = fibCurrentActive ? (h1Close - fibMonthLow) / fibCurrentRange : na
fibPreviousRatio = fibPreviousActive ? (h1Close - fibPreviousLow) / fibPreviousRange : na
fibTransitionRangeRatio = fibCurrentActive and fibPreviousActive ? fibCurrentRange / fibPreviousRange : na
fibTransitionSameSide = not na(fibCurrentRatio) and not na(fibPreviousRatio) and ((fibCurrentRatio <= 0.5) == (fibPreviousRatio <= 0.5))
fibEarlyRelay = fibCurrentTradingDays >= fibTransitionMinDays and not na(fibTransitionRangeRatio) and fibTransitionRangeRatio >= fibTransitionMinRangePct / 100.0 and fibTransitionSameSide
fibForcedRelay = utcDay >= fibTransitionForceDay
usePreviousFib = fibPreviousActive and not fibEarlyRelay and not fibForcedRelay
effectiveMonthKey = usePreviousFib ? fibPreviousMonthKey : currentMonthKey
effectiveMonthId = usePreviousFib ? fibPreviousMonthId : currentMonthId
effectiveMonthChanged = not na(effectiveMonthId[1]) and effectiveMonthId != effectiveMonthId[1]
fibSourceText = usePreviousFib ? "M-1" : "M"
fibEffectiveStartTime = usePreviousFib ? fibPreviousStartTime : fibMonthStartTime
fibRange = usePreviousFib ? fibPreviousRange : fibCurrentRange
fibActive = not na(fibRange) and fibRange > 0.0
fib0 = usePreviousFib ? fibPreviousLow : fibMonthLow
fib1 = usePreviousFib ? fibPreviousHigh : fibMonthHigh
fib236 = fib0 + fibRange * 0.236
fib382 = fib0 + fibRange * 0.382
fib500 = fib0 + fibRange * 0.500
fib618 = fib0 + fibRange * 0.618
fib786 = fib0 + fibRange * 0.786
fibRatio = fibActive ? (h1Close - fib0) / fibRange : na
fibPct = fibRatio * 100.0
fibEndTime = h1Time + 60 * 60 * 1000 * fibExtendBars

sarDirection = h1Close > sarValue ? 1 : h1Close < sarValue ? -1 : 0
sarCrossBull = ta.crossover(h1Close, sarValue)
sarCrossBear = ta.crossunder(h1Close, sarValue)
sarCrossDirection = sarCrossBull ? 1 : sarCrossBear ? -1 : 0

h1BeyondBull = h1Close > streakHighM and h1Close > streakHighW and h1Close > streakHighD
h1BeyondBear = h1Close < streakLowM and h1Close < streakLowW and h1Close < streakLowD
renkoFiboBull = confirmedState == 1 and h1BeyondBull and sarDirection == 1
renkoFiboBear = confirmedState == -1 and h1BeyondBear and sarDirection == -1

timeframeOk = timeframe.in_seconds(timeframe.period) == 3600
processBar = timeframeOk and barstate.isconfirmed and dataReady and fibActive

// Persistent single-pair VIVIER state.
var int vivierDirection = 0
var float sarRecord = na
var int flameCount = 0
var int fib1TouchCount = 0
var int fib0TouchCount = 0
var string lastEvent = "AUCUN"
var float fibObjective = na
var int fibObjectiveDirection = 0
var string fibObjectiveOriginMonth = ""
var bool fibObjectiveCarried = false
var bool postAlignmentObjective = false
var line carriedObjectiveLine = na
var label carriedObjectiveLabel = na

bool entryEvent = false
int entryEventDirection = 0
bool invalidExitEvent = false
int invalidExitDirection = 0
bool alignmentEvent = false
int alignmentEventDirection = 0
bool renkoFiboTransitionEvent = false
bool flameEvent = false
int flameEventDirection = 0
bool initialFlameEvent = false
bool fibTouchEvent = false
int fibTouchDirection = 0
float fibTouchLevel = na
bool fibResetEvent = false
bool objectiveCarryEvent = false
float objectiveCarryLevel = na
int objectiveCarryDirection = 0
bool objectiveTouchEvent = false
bool objectiveTouchWasCarried = false
float objectiveTouchLevel = na
int objectiveTouchDirection = 0
bool postObjectiveCreatedEvent = false
bool postObjectiveReachedEvent = false
bool postObjectiveCanceledEvent = false
bool postObjectiveReattachedEvent = false
int postObjectiveEventDirection = 0
float postObjectiveEventLevel = na

if processBar
    if vivierDirection != 0
        int activeDirection = vivierDirection
        bool fullAlignment = pxM == activeDirection and pxW == activeDirection and pxD == activeDirection
        if fullAlignment
            alignmentEvent := true
            alignmentEventDirection := activeDirection
            renkoFiboTransitionEvent := activeDirection == 1 ? renkoFiboBull : renkoFiboBear
            lastEvent := renkoFiboTransitionEvent ? "VIVIER -> RENKO FIBO " + f_dir_text(activeDirection) : "ALIGNEMENT " + f_dir_text(activeDirection)
            if not na(fibObjective)
                postAlignmentObjective := true
                fibObjectiveCarried := true
                postObjectiveCreatedEvent := true
                postObjectiveEventDirection := activeDirection
                postObjectiveEventLevel := fibObjective
                if showCarriedObjective
                    if na(carriedObjectiveLine)
                        carriedObjectiveLine := line.new(h1Time, fibObjective, h1Time + 60 * 60 * 1000, fibObjective, xloc=xloc.bar_time, extend=extend.right, color=carriedObjectiveColor, style=line.style_dashed, width=2)
                        carriedObjectiveLabel := label.new(h1Time, fibObjective, "OBJECTIF POST-ALIGNEMENT\n" + f_dir_text(activeDirection) + " " + str.tostring(fibObjective, format.mintick) + "\nOrigine " + fibObjectiveOriginMonth, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_left, color=color.new(color.white, 100), textcolor=carriedObjectiveColor, size=size.small)
                    else if not na(carriedObjectiveLabel)
                        label.set_text(carriedObjectiveLabel, "OBJECTIF POST-ALIGNEMENT\n" + f_dir_text(activeDirection) + " " + str.tostring(fibObjective, format.mintick) + "\nOrigine " + fibObjectiveOriginMonth)
            vivierDirection := 0
            sarRecord := na
        else if pxM == activeDirection and math.abs(baseScorePct) >= vivierMinScore
            if effectiveMonthChanged and not na(fibObjective) and not fibObjectiveCarried
                fibObjectiveCarried := true
                objectiveCarryEvent := true
                objectiveCarryLevel := fibObjective
                objectiveCarryDirection := activeDirection
                lastEvent := "OBJECTIF " + (activeDirection == 1 ? "FIB 1" : "FIB 0") + " REPORTE"
                if showCarriedObjective
                    carriedObjectiveLine := line.new(h1Time, fibObjective, h1Time + 60 * 60 * 1000, fibObjective, xloc=xloc.bar_time, extend=extend.right, color=carriedObjectiveColor, style=line.style_dashed, width=2)
                    carriedObjectiveLabel := label.new(h1Time, fibObjective, "OBJECTIF REPORTE\n" + f_dir_text(activeDirection) + " " + str.tostring(fibObjective, format.mintick) + "\nOrigine " + fibObjectiveOriginMonth, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_left, color=color.new(color.white, 100), textcolor=carriedObjectiveColor, size=size.small)

            bool touchedCurrentExtreme = activeDirection == 1 ? not na(fibHighBefore) and h1High >= fibHighBefore : not na(fibLowBefore) and h1Low <= fibLowBefore
            bool touchedObjective = activeDirection == 1 ? not na(fibObjective) and h1High >= fibObjective : not na(fibObjective) and h1Low <= fibObjective
            if touchedCurrentExtreme
                fibTouchEvent := true
                fibTouchDirection := activeDirection
                fibTouchLevel := activeDirection == 1 ? fibHighBefore : fibLowBefore
                if activeDirection == 1
                    fib1TouchCount += 1
                else
                    fib0TouchCount += 1
                lastEvent := activeDirection == 1 ? "FIB 1 TOUCH" : "FIB 0 TOUCH"

            if touchedObjective
                objectiveTouchEvent := true
                objectiveTouchWasCarried := fibObjectiveCarried
                objectiveTouchLevel := fibObjective
                objectiveTouchDirection := activeDirection
                if not na(sarRecord)
                    fibResetEvent := true
                    sarRecord := na
                lastEvent := (objectiveTouchWasCarried ? "OBJECTIF REPORTE TOUCHE" : "OBJECTIF TOUCHE") + (fibResetEvent ? " - FLAMME REARMEE" : "")
                f_finish_carried_line(carriedObjectiveLine, carriedObjectiveLabel, h1Time, "ATTEINT", carriedObjectiveColor)
                carriedObjectiveLine := na
                carriedObjectiveLabel := na
                fibObjective := na
                fibObjectiveDirection := 0
                fibObjectiveCarried := false
                postAlignmentObjective := false

            if not touchedObjective and f_new_sar_record(activeDirection, sarCrossDirection, sarValue, fib500, sarRecord)
                initialFlameEvent := na(sarRecord)
                sarRecord := sarValue
                flameCount += 1
                flameEvent := true
                flameEventDirection := activeDirection
                if na(fibObjective)
                    fibObjective := activeDirection == 1 ? fib1 : fib0
                    fibObjectiveDirection := activeDirection
                    fibObjectiveOriginMonth := effectiveMonthKey
                    fibObjectiveCarried := false
                lastEvent := (initialFlameEvent ? "FLAMME INITIALE " : "FLAMME RECORD ") + f_dir_text(activeDirection)
        else
            invalidExitEvent := true
            invalidExitDirection := activeDirection
            lastEvent := pxM != activeDirection ? "SORTIE: MONTHLY INVALIDE" : "SORTIE: SCORE < " + str.tostring(vivierMinScore, "#") + "%"
            f_finish_carried_line(carriedObjectiveLine, carriedObjectiveLabel, h1Time, "ANNULE", neutralColor)
            carriedObjectiveLine := na
            carriedObjectiveLabel := na
            vivierDirection := 0
            sarRecord := na
            fibObjective := na
            fibObjectiveDirection := 0
            fibObjectiveCarried := false
            postAlignmentObjective := false

    if vivierDirection == 0 and postAlignmentObjective and not na(fibObjective)
        bool postMonthlyValid = pxM == fibObjectiveDirection
        bool postTargetTouched = fibObjectiveDirection == 1 ? h1High >= fibObjective : h1Low <= fibObjective
        if not postMonthlyValid
            postObjectiveCanceledEvent := true
            postObjectiveEventDirection := fibObjectiveDirection
            postObjectiveEventLevel := fibObjective
            lastEvent := "OBJECTIF POST-ALIGNEMENT ANNULE"
            f_finish_carried_line(carriedObjectiveLine, carriedObjectiveLabel, h1Time, "ANNULE", neutralColor)
            carriedObjectiveLine := na
            carriedObjectiveLabel := na
            fibObjective := na
            fibObjectiveDirection := 0
            fibObjectiveCarried := false
            postAlignmentObjective := false
        else if postTargetTouched
            postObjectiveReachedEvent := true
            postObjectiveEventDirection := fibObjectiveDirection
            postObjectiveEventLevel := fibObjective
            lastEvent := "OBJECTIF POST-SIGNAL ATTEINT"
            f_finish_carried_line(carriedObjectiveLine, carriedObjectiveLabel, h1Time, "ATTEINT", carriedObjectiveColor)
            carriedObjectiveLine := na
            carriedObjectiveLabel := na
            fibObjective := na
            fibObjectiveDirection := 0
            fibObjectiveCarried := false
            postAlignmentObjective := false

    // Python can switch directly to the opposite pool after invalidating the
    // previous direction, but never re-enters on the alignment event itself.
    if vivierDirection == 0 and not alignmentEvent
        int candidateDirection = f_entry_direction(pxM, pxW, pxD, baseScorePct, fibPct)
        if candidateDirection != 0
            bool reusePostObjective = postAlignmentObjective and fibObjectiveDirection == candidateDirection and not na(fibObjective)
            vivierDirection := candidateDirection
            entryEvent := true
            entryEventDirection := candidateDirection
            sarRecord := na
            flameCount := 0
            fib1TouchCount := 0
            fib0TouchCount := 0
            if reusePostObjective
                postAlignmentObjective := false
                postObjectiveReattachedEvent := true
                postObjectiveEventDirection := candidateDirection
                postObjectiveEventLevel := fibObjective
                fibObjectiveCarried := true
                if not na(carriedObjectiveLabel)
                    label.set_text(carriedObjectiveLabel, "OBJECTIF REATTACHE AU VIVIER\n" + f_dir_text(candidateDirection) + " " + str.tostring(fibObjective, format.mintick) + "\nOrigine " + fibObjectiveOriginMonth)
                lastEvent := "REENTREE + OBJECTIF REATTACHE " + f_dir_text(candidateDirection)
            else
                fibObjective := candidateDirection == 1 ? fib1 : fib0
                fibObjectiveDirection := candidateDirection
                fibObjectiveOriginMonth := effectiveMonthKey
                fibObjectiveCarried := false
                postAlignmentObjective := false
                carriedObjectiveLine := na
                carriedObjectiveLabel := na
                lastEvent := "ENTREE VIVIER " + f_dir_text(candidateDirection)
            if f_new_sar_record(candidateDirection, sarCrossDirection, sarValue, fib500, sarRecord)
                initialFlameEvent := true
                sarRecord := sarValue
                flameCount += 1
                flameEvent := true
                flameEventDirection := candidateDirection
                lastEvent := "ENTREE + FLAMME " + f_dir_text(candidateDirection)

displayDirection = vivierDirection != 0 ? vivierDirection : postAlignmentObjective ? fibObjectiveDirection : pxM
fibDirectionalText = f_fib_directional_text(fibRatio, displayDirection)
sameFibAndObjectiveTouch = fibTouchEvent and objectiveTouchEvent and math.abs(fibTouchLevel - objectiveTouchLevel) <= syminfo.mintick

plot(showSar ? sarValue : na, "H1 SAR", style=plot.style_line, color=sarColor, linewidth=2)
plotshape(showAllSarCrosses and sarCrossBull and barstate.isconfirmed, "SAR Crossover", shape.triangleup, location.belowbar, color=color.new(bullColor, 45), size=size.tiny, text="SAR+")
plotshape(showAllSarCrosses and sarCrossBear and barstate.isconfirmed, "SAR Crossunder", shape.triangledown, location.abovebar, color=color.new(bearColor, 45), size=size.tiny, text="SAR-")
bgcolor(showVivierBackground ? vivierDirection == 1 ? color.new(bullColor, 92) : vivierDirection == -1 ? color.new(bearColor, 92) : postAlignmentObjective ? color.new(carriedObjectiveColor, 94) : na : na, title="VIVIER Background")

if showEventLabels and entryEvent
    float entryY = entryEventDirection == 1 ? h1Low : h1High
    string reattachedText = postObjectiveReattachedEvent ? "\nOBJECTIF POST-SIGNAL REATTACHE" : ""
    label.new(bar_index, entryY, "VIVIER " + f_dir_text(entryEventDirection) + "\n" + f_px_text(pxM, pxW, pxD) + " | " + f_fib_directional_text(fibRatio, entryEventDirection) + " | " + fibSourceText + reattachedText, yloc=yloc.price, style=entryEventDirection == 1 ? label.style_label_up : label.style_label_down, color=f_dir_color(entryEventDirection), textcolor=color.white, size=size.small)

if showEventLabels and flameEvent
    string flameName = initialFlameEvent ? "FLAMME INITIALE " : "FLAMME RECORD "
    label.new(bar_index, sarValue, flameName + f_dir_text(flameEventDirection) + "\nSAR " + str.tostring(sarValue, format.mintick), yloc=yloc.price, style=flameEventDirection == 1 ? label.style_label_up : label.style_label_down, color=color.new(color.orange, 0), textcolor=color.white, size=size.small)

if showEventLabels and showAllProcessTouches and fibTouchEvent and not sameFibAndObjectiveTouch
    string touchName = fibTouchDirection == 1 ? "FIB 1 TOUCH" : "FIB 0 TOUCH"
    label.new(bar_index, fibTouchLevel, touchName + "\n" + str.tostring(fibTouchLevel, format.mintick), yloc=yloc.price, style=fibTouchDirection == 1 ? label.style_label_down : label.style_label_up, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)

if showEventLabels and objectiveTouchEvent
    string objectiveName = objectiveTouchWasCarried ? "OBJECTIF REPORTE ATTEINT" : "OBJECTIF ATTEINT"
    string objectiveResetText = fibResetEvent ? "\nREARMEMENT FLAMME" : ""
    label.new(bar_index, objectiveTouchLevel, objectiveName + objectiveResetText + "\n" + str.tostring(objectiveTouchLevel, format.mintick), yloc=yloc.price, style=objectiveTouchDirection == -1 ? label.style_label_up : label.style_label_down, color=objectiveTouchWasCarried ? carriedObjectiveColor : color.orange, textcolor=color.white, size=size.small)

if showEventLabels and postObjectiveReachedEvent
    label.new(bar_index, postObjectiveEventLevel, "OBJECTIF POST-SIGNAL ATTEINT\n" + f_dir_text(postObjectiveEventDirection) + " " + str.tostring(postObjectiveEventLevel, format.mintick), yloc=yloc.price, style=postObjectiveEventDirection == -1 ? label.style_label_up : label.style_label_down, color=carriedObjectiveColor, textcolor=color.white, size=size.normal)

if showEventLabels and postObjectiveCanceledEvent
    label.new(bar_index, h1Close, "OBJECTIF POST-SIGNAL ANNULE\nMONTHLY INVALIDE", yloc=yloc.price, style=label.style_label_left, color=neutralColor, textcolor=color.white, size=size.small)

if showEventLabels and alignmentEvent
    string alignmentText = renkoFiboTransitionEvent ? "VIVIER -> RENKO FIBO" : "ALIGNEMENT COMPLET"
    string postTrackingText = postObjectiveReachedEvent ? "\nOBJECTIF ATTEINT" : postObjectiveCreatedEvent ? "\nOBJECTIF CONSERVE" : ""
    label.new(bar_index, h1Close, alignmentText + "\n" + f_dir_text(alignmentEventDirection) + postTrackingText, yloc=yloc.price, style=alignmentEventDirection == 1 ? label.style_label_up : label.style_label_down, color=renkoFiboTransitionEvent ? color.new(color.blue, 0) : f_dir_color(alignmentEventDirection), textcolor=color.white, size=size.normal)

if showEventLabels and invalidExitEvent
    label.new(bar_index, h1Close, "SORTIE VIVIER " + f_dir_text(invalidExitDirection) + "\nINVALIDE", yloc=yloc.price, style=label.style_label_left, color=neutralColor, textcolor=color.white, size=size.tiny)

var line fibLine0 = line.new(na, na, na, na, xloc=xloc.bar_time, color=fibLowColor, style=line.style_dotted, width=2)
var line fibLine236 = line.new(na, na, na, na, xloc=xloc.bar_time, color=fibColor, style=line.style_dotted, width=2)
var line fibLine382 = line.new(na, na, na, na, xloc=xloc.bar_time, color=fibColor, style=line.style_dotted, width=2)
var line fibLine500 = line.new(na, na, na, na, xloc=xloc.bar_time, color=fibColor, style=line.style_dotted, width=2)
var line fibLine618 = line.new(na, na, na, na, xloc=xloc.bar_time, color=fibColor, style=line.style_dotted, width=2)
var line fibLine786 = line.new(na, na, na, na, xloc=xloc.bar_time, color=fibColor, style=line.style_dotted, width=2)
var line fibLine1 = line.new(na, na, na, na, xloc=xloc.bar_time, color=fibHighColor, style=line.style_dotted, width=2)
var label fibLabel0 = label.new(na, na, "", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), size=size.small)
var label fibLabel236 = label.new(na, na, "", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), size=size.small)
var label fibLabel382 = label.new(na, na, "", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), size=size.small)
var label fibLabel500 = label.new(na, na, "", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), size=size.small)
var label fibLabel618 = label.new(na, na, "", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), size=size.small)
var label fibLabel786 = label.new(na, na, "", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), size=size.small)
var label fibLabel1 = label.new(na, na, "", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), size=size.small)

if barstate.islast
    f_update_fib(fibLine0, fibLabel0, showFibExtremes, fibActive, fibEffectiveStartTime, fibEndTime, fib0, "0 " + fibSourceText, fibLowColor)
    f_update_fib(fibLine236, fibLabel236, showFib236, fibActive, fibEffectiveStartTime, fibEndTime, fib236, "0.236 " + fibSourceText, fibColor)
    f_update_fib(fibLine382, fibLabel382, showFib382, fibActive, fibEffectiveStartTime, fibEndTime, fib382, "0.382 " + fibSourceText, fibColor)
    f_update_fib(fibLine500, fibLabel500, showFib500, fibActive, fibEffectiveStartTime, fibEndTime, fib500, "0.500 " + fibSourceText, fibColor)
    f_update_fib(fibLine618, fibLabel618, showFib618, fibActive, fibEffectiveStartTime, fibEndTime, fib618, "0.618 " + fibSourceText, fibColor)
    f_update_fib(fibLine786, fibLabel786, showFib786, fibActive, fibEffectiveStartTime, fibEndTime, fib786, "0.786 " + fibSourceText, fibColor)
    f_update_fib(fibLine1, fibLabel1, showFibExtremes, fibActive, fibEffectiveStartTime, fibEndTime, fib1, "1 " + fibSourceText, fibHighColor)

var table vivierTable = table.new(f_table_position(tablePosition), 2, 3, border_width=1, frame_color=color.white, border_color=color.gray)
if barstate.islast
    string statusText = vivierDirection != 0 ? "VIVIER " + f_dir_text(vivierDirection) : postAlignmentObjective ? "SUIVI POST-ALIGNEMENT " + f_dir_text(fibObjectiveDirection) : "HORS VIVIER"
    color statusColor = vivierDirection != 0 ? f_dir_color(vivierDirection) : postAlignmentObjective ? carriedObjectiveColor : neutralColor
    string scoreText = na(baseScorePct) ? "?" : (baseScorePct >= 0.0 ? "+" : "") + str.tostring(baseScorePct, "#.0") + "%"
    string fibText = na(fibPct) ? "?" : fibDirectionalText

    table.cell(vivierTable, 0, 0, "STATUT", bgcolor=headerColor, text_color=color.white)
    table.cell(vivierTable, 1, 0, statusText, bgcolor=statusColor, text_color=color.white)
    table.cell(vivierTable, 0, 1, "SCORE", bgcolor=headerColor, text_color=color.white)
    table.cell(vivierTable, 1, 1, scoreText, bgcolor=f_dir_color(baseScorePct > 0 ? 1 : baseScorePct < 0 ? -1 : 0), text_color=color.white)
    table.cell(vivierTable, 0, 2, "FIBO", bgcolor=headerColor, text_color=color.white)
    table.cell(vivierTable, 1, 2, fibText, bgcolor=neutralColor, text_color=color.white)

alertcondition(entryEvent, "VIVIER Entry", "🌱 {{ticker}} ENTRE VIVIER")
alertcondition(flameEvent, "VIVIER SAR Flame", "🔥 {{ticker}} FLAMME")
alertcondition(objectiveCarryEvent, "VIVIER Objective Carried", "📌 {{ticker}} OBJECTIF REPORTE")
alertcondition(objectiveTouchEvent, "VIVIER Objective Reached", "🎯 {{ticker}} OBJECTIF ATTEINT")
alertcondition(postObjectiveCreatedEvent, "Post-Alignment Objective Started", "🎯 {{ticker}} OBJECTIF SUIVI")
alertcondition(postObjectiveReachedEvent, "Post-Alignment Objective Reached", "🎯 {{ticker}} OBJECTIF ATTEINT")
alertcondition(postObjectiveCanceledEvent, "Post-Alignment Objective Canceled", "❌ {{ticker}} OBJECTIF ANNULE")
alertcondition(postObjectiveReattachedEvent, "Post-Alignment Objective Reattached", "🔄 {{ticker}} OBJECTIF REATTACHE")
alertcondition(fibResetEvent, "VIVIER Fibonacci Rearm", "🔄 {{ticker}} FLAMME REARMEE")
alertcondition(alignmentEvent, "VIVIER Alignment", "✅ {{ticker}} ALIGNE")
alertcondition(renkoFiboTransitionEvent, "VIVIER to RENKO FIBO", "🚨 {{ticker}} RENKO FIBO")
alertcondition(invalidExitEvent, "VIVIER Invalid Exit", "❌ {{ticker}} HORS VIVIER")

if processBar
    if entryEvent
        alert("🌱 " + syminfo.ticker + " " + f_dir_text(entryEventDirection) + " " + f_fib_directional_text(fibRatio, entryEventDirection), alert.freq_once_per_bar_close)
    if flameEvent
        alert("🔥 " + syminfo.ticker + " " + f_dir_text(flameEventDirection), alert.freq_once_per_bar_close)
    if objectiveCarryEvent
        alert("📌 " + syminfo.ticker + " " + (objectiveCarryDirection == 1 ? "F1" : "F0") + " REPORTE", alert.freq_once_per_bar_close)
    if objectiveTouchEvent
        alert("🎯 " + syminfo.ticker + " " + (objectiveTouchDirection == 1 ? "F1" : "F0") + " ATTEINT" + (fibResetEvent ? " 🔄" : ""), alert.freq_once_per_bar_close)
    if postObjectiveCreatedEvent
        alert("🎯 " + syminfo.ticker + " " + (postObjectiveEventDirection == 1 ? "F1" : "F0") + " SUIVI", alert.freq_once_per_bar_close)
    if postObjectiveReachedEvent
        alert("🎯 " + syminfo.ticker + " " + (postObjectiveEventDirection == 1 ? "F1" : "F0") + " ATTEINT", alert.freq_once_per_bar_close)
    if postObjectiveCanceledEvent
        alert("❌ " + syminfo.ticker + " " + (postObjectiveEventDirection == 1 ? "F1" : "F0") + " ANNULE", alert.freq_once_per_bar_close)
    if postObjectiveReattachedEvent
        alert("🔄 " + syminfo.ticker + " " + (postObjectiveEventDirection == 1 ? "F1" : "F0") + " REATTACHE", alert.freq_once_per_bar_close)
    if alignmentEvent
        alert((renkoFiboTransitionEvent ? "🚨 " : "✅ ") + syminfo.ticker + " " + f_dir_text(alignmentEventDirection) + (renkoFiboTransitionEvent ? " RENKO FIBO" : " ALIGNE"), alert.freq_once_per_bar_close)
    if invalidExitEvent
        alert("❌ " + syminfo.ticker + " HORS VIVIER", alert.freq_once_per_bar_close)
